{
  "name": "crafttogether",
  "version": "0.1.0",
  "private": true,
  "description": "Companion app (Android + iOS) to find rooms and play Minecraft Bedrock with friends. Unofficial, no game files bundled.",
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "server:dev": "pnpm --filter @crafttogether/server dev",
    "app:start": "pnpm --filter @crafttogether/app start"
  }
}

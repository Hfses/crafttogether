# ---- Backend (server/) ----
# HTTP + WebSocket signaling port
PORT=8080
# UDP relay listening port (host/guest proxies send RakNet packets here)
RELAY_PORT=19133
# Public host/IP that clients use to reach the relay (set to your server's public IP/domain in prod)
PUBLIC_HOST=127.0.0.1
# Seconds of inactivity before a room/session is garbage-collected
SESSION_TTL_SECONDS=180

# ---- App (app/) ----
# Base URL of the backend the mobile app talks to.
# For local dev with Expo Go on a physical phone, use your computer's LAN IP, e.g. http://192.168.0.10:8080
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080
